#include <iostream>
#include <vector>
#include <unordered_map>
using namespace std;

struct TreeNode {
    int val;
    TreeNode *left;
    TreeNode *right;

    TreeNode(int x) : val(x), left(nullptr), right(nullptr) {}
};

class Solution {
public:
    TreeNode* createBinaryTree(vector<vector<int>>& A) {
        unordered_map<int, TreeNode*> nodes;
        nodes.reserve(A.size() + 1);
        int root = 0;

        for (auto& d : A) {
            int x = d[0], y = d[1], isLeft = d[2];

            if (!nodes.count(x)) {
                nodes[x] = new TreeNode(x);
                root ^= x;
            }

            if (!nodes.count(y)) {
                nodes[y] = new TreeNode(y);
                root ^= y;
            }

            if (isLeft)
                nodes[x]->left = nodes[y];
            else
                nodes[x]->right = nodes[y];

            root ^= y;
        }

        return nodes[root];
    }
};

void preorder(TreeNode* root) {
    if (!root) return;
    cout << root->val << " ";
    preorder(root->left);
    preorder(root->right);
}

int main() {
    vector<vector<int>> descriptions = {
        {20, 15, 1},
        {20, 17, 0},
        {15, 10, 1},
        {15, 12, 0}
    };

    Solution sol;
    TreeNode* root = sol.createBinaryTree(descriptions);

    cout << "Preorder Traversal: ";
    preorder(root);
    cout << endl;

    return 0;
}
