#include <bits/stdc++.h>
using namespace std;

class Solution {
public:
    int closestTarget(vector<string>& words, string target, int start) {
        int n = words.size();
        for (int i = 0; i <= (n >> 1); i++)
            if (words[(start + i) % n] == target ||
                words[(start - i + n) % n] == target)
                return i;
        return -1;
    }
};

int main() {
    int n;
    cin >> n;

    vector<string> words(n);
    for (int i = 0; i < n; i++) cin >> words[i];

    string target;
    cin >> target;

    int start;
    cin >> start;

    Solution obj;
    cout << obj.closestTarget(words, target, start);

    return 0;
}
