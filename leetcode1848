#include <bits/stdc++.h>
using namespace std;

class Solution {
public:
    int getMinDistance(vector<int>& nums, int target, int start) {
        int result = nums.size();
        for(int i = 0; i < nums.size(); i++) {
            if(nums[i] == target)
                result = min(result, abs(i - start));
        }
        return result;
    }
};

int main() {
    Solution obj;
    vector<int> nums = {1, 2, 3, 4, 5};
    int target = 5;
    int start = 3;

    int ans = obj.getMinDistance(nums, target, start);

    cout << "Minimum Distance: " << ans << endl;

    return 0;
}
