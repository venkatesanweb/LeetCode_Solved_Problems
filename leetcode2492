#include <bits/stdc++.h>
using namespace std;

class Solution {
public:
    int minScore(int n, vector<vector<int>>& roads) {
        vector<int> root(n + 1);
        iota(root.begin(), root.end(), 0);

        auto find = [&](auto&& self, int i) -> int {
            return root[i] == i ? i : root[i] = self(self, root[i]);
        };

        for (auto& r : roads)
            root[find(find, r[0])] = find(find, r[1]);

        int res = INT_MAX;

        for (auto& r : roads)
            if (find(find, r[0]) == find(find, 1))
                res = min(res, r[2]);

        return res;
    }
};

int main() {
    int n, m;
    cin >> n >> m;

    vector<vector<int>> roads(m, vector<int>(3));

    for (int i = 0; i < m; i++)
        cin >> roads[i][0] >> roads[i][1] >> roads[i][2];

    Solution sol;
    cout << sol.minScore(n, roads);

    return 0;
}
