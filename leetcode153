#include <iostream>
#include <vector>
using namespace std;

class Solution {
public:
    int findMin(vector<int>& nums) {

        int l = 0, r = nums.size() - 1, mid;

        while (l < r) {

            mid = (l + r) / 2;

            if (nums[mid] < nums[r]) {
                r = mid;
            }
            else {
                l = mid + 1;
            }
        }

        return nums[l];
    }
};

int main() {

    vector<int> nums = {4, 5, 6, 7, 0, 1, 2};

    Solution obj;

    cout << "Minimum element: " << obj.findMin(nums);

    return 0;
}
