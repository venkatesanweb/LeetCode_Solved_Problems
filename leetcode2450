#include <bits/stdc++.h>
using namespace std;

class Solution {
public:
    static int getCommon(vector<int>& nums1, vector<int>& nums2) {
        int n1 = nums1.size(), n2 = nums2.size();
        int p1 = 0, p2 = 0;

        while (p1 < n1 && p2 < n2) {
            int x = nums1[p1], y = nums2[p2];

            if (x == y)
                return x;
            else if (x > y)
                p2++;
            else
                p1++;
        }

        return -1;
    }
};

auto init = []() {
    ios::sync_with_stdio(0);
    cin.tie(0);
    cout.tie(0);
    return 'c';
}();

int main() {
    int n1, n2;

    cin >> n1;
    vector<int> nums1(n1);

    for (int i = 0; i < n1; i++)
        cin >> nums1[i];

    cin >> n2;
    vector<int> nums2(n2);

    for (int i = 0; i < n2; i++)
        cin >> nums2[i];

    cout << Solution::getCommon(nums1, nums2);

    return 0;
}
