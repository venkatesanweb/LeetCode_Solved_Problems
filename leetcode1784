#include <bits/stdc++.h>
using namespace std;

class Solution {
public:
    bool checkOnesSegment(string& s) {
        const int n = s.size();

        int i0 = 0;
        while (i0 < n && s[i0] == '1')
            i0++;

        if (i0 == n)
            return true;

        int i1 = n - 1;
        while (i1 >= 0 && s[i1] == '0')
            i1--;

        return i0 > i1;
    }
};

int main() {
    string s;
    cout << "Enter binary string: ";
    cin >> s;

    Solution obj;

    if (obj.checkOnesSegment(s))
        cout << "True - Only one segment of 1s\n";
    else
        cout << "False - More than one segment of 1s\n";

    return 0;
}
