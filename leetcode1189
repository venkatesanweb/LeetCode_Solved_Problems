#include <iostream>
#include <string>
#include <algorithm>
using namespace std;

class Solution {
public:
    int maxNumberOfBalloons(string t) {
        int f[5] = {0};
        string s = "balon";

        for (char ch : t)
            for (int i = 0; i < 5; i++)
                f[i] += !(ch ^ s[i]);

        return min({f[0], f[1], f[2] >> 1, f[3] >> 1, f[4]});
    }
};

int main() {
    Solution obj;

    string text;
    cout << "Enter the string: ";
    cin >> text;

    cout << "Maximum number of times \"balloon\" can be formed: "
         << obj.maxNumberOfBalloons(text) << endl;

    return 0;
}
