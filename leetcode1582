#include <bits/stdc++.h>
using namespace std;

class Solution {
public:
    static vector<int> check1(vector<int>& vect, int sz){
        vector<int> ans;
        for(int i = 0; i < sz; i++){
            if (vect[i] == 1)
                ans.push_back(i);
        }
        return ans;
    }

    static int numSpecial(vector<vector<int>>& mat) {
        int m = mat.size();
        int n = mat[0].size();
        int ans = 0;

        vector<bool> col(n, 0);

        for(int i = 0; i < m; i++){
            auto idx = check1(mat[i], n);
            int j;

            if (idx.size() == 1 && col[(j = idx[0])] == 0){
                col[j] = 1;
                int count_col1 = 0;

                for(int k = 0; k < m; k++)
                    count_col1 += mat[k][j];

                if (count_col1 == 1){
                    ans++;
                }
            }
            else{
                for(int j : idx)
                    col[j] = 1;
            }
        }
        return ans;
    }
};

auto init = []() {
    ios::sync_with_stdio(0);
    cin.tie(0);
    cout.tie(0);
    return 'c';
}();

int main() {
    int m, n;
    cin >> m >> n;

    vector<vector<int>> mat(m, vector<int>(n));

    for(int i = 0; i < m; i++){
        for(int j = 0; j < n; j++){
            cin >> mat[i][j];
        }
    }

    cout << Solution::numSpecial(mat);

    return 0;
}
