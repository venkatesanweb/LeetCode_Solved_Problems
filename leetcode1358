#include <iostream>
#include <string>
#include <algorithm>
using namespace std;

class Solution {
public:
    int numberOfSubstrings(string s) {
        int res = 0;
        int p[3] = {-1, -1, -1};

        for (int i = 0; i < s.length(); i++) {
            p[(s[i] & 31) - 1] = i;   // stores latest index of a, b, c
            res += min({p[0], p[1], p[2]}) + 1;
        }

        return res;
    }
};

int main() {
    Solution obj;

    string s;
    cout << "Enter the string: ";
    cin >> s;

    cout << "Number of substrings containing a, b, and c: "
         << obj.numberOfSubstrings(s) << endl;

    return 0;
}
