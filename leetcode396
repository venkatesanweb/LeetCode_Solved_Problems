#include <bits/stdc++.h>
using namespace std;

class Solution {
public:
    int maxRotateFunction(vector<int>& A) {
        int sum = 0, F = 0;
        int n = A.size();

        for (int i = 0; i < n; i++) {
            sum += A[i];
            F += i * A[i];
        }

        int maxi = F;

        for (int i = 1; i < n; i++) {
            F += sum - n * A[n - i];
            maxi = max(maxi, F);
        }

        return maxi;
    }
};

int main() {
    Solution obj;
    
    int n;
    cout << "Enter size of array: ";
    cin >> n;

    vector<int> A(n);
    cout << "Enter elements: ";
    for (int i = 0; i < n; i++) {
        cin >> A[i];
    }

    int result = obj.maxRotateFunction(A);
    cout << "Maximum Rotate Function: " << result << endl;

    return 0;
}
