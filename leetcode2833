#include <iostream>
#include <string>
#include <cmath>
using namespace std;

class Solution {
public:
    int furthestDistanceFromOrigin(string moves) {
        int left = 0, right = 0, blanks = 0;

        for (char c : moves) {
            if (c == 'L') left++;
            else if (c == 'R') right++;
            else blanks++;
        }

        return abs(left - right) + blanks;
    }
};

int main() {
    Solution sol;
    string moves;

    cout << "Enter moves string (L, R, _): ";
    cin >> moves;

    int result = sol.furthestDistanceFromOrigin(moves);
    cout << "Furthest distance from origin: " << result << endl;

    return 0;
}
