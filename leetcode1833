#include <iostream>
#include <vector>
#include <algorithm>
using namespace std;

constexpr int M = 1e5 + 1;
int freq[M];

class Solution {
public:
    static int maxIceCream(vector<int>& costs, int coins) {
        int xMax = 0;

        for (int x : costs) {
            freq[x]++;
            xMax = max(xMax, x);
        }

        int cnt = 0;

        for (int x = 1; x <= xMax; x++) {
            int f = freq[x];

            if (f == 0)
                continue;

            int buy = min(coins / x, f);

            if (buy == 0)
                break;

            cnt += buy;
            coins -= buy * x;
        }

        // Reset frequency array
        for (int x : costs)
            freq[x] = 0;

        return cnt;
    }
};

auto init = []() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    cout.tie(nullptr);
    return 'c';
}();

int main() {
    int n, coins;

    cin >> n;
    vector<int> costs(n);

    for (int i = 0; i < n; i++) {
        cin >> costs[i];
    }

    cin >> coins;

    cout << Solution::maxIceCream(costs, coins) << '\n';

    return 0;
}
