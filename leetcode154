#include <iostream>
#include <vector>
using namespace std;

class Solution {
public:
    int findMin(vector<int>& nums) {
        int l = 0;
        int r = nums.size() - 1;

        while(l < r) {

            int mid = l + (r - l) / 2;

            if(nums[mid] < nums[r]) {
                r = mid;
            }
            else if(nums[mid] > nums[r]) {
                l = mid + 1;
            }
            else {
                r--;
            }
        }

        return nums[l];
    }
};

int main() {
    Solution obj;

    vector<int> nums = {2, 2, 2, 0, 1};

    int result = obj.findMin(nums);

    cout << "Minimum element: " << result << endl;

    return 0;
}
