#include <iostream>
#include <vector>
#include <string>
using namespace std;

class Solution {
public:
    vector<int> separateDigits(vector<int>& nums) {
        vector<int> res;

        for (int i : nums) {
            string s = to_string(i);

            for (char c : s) {
                res.push_back(c - '0');
            }
        }

        return res;
    }
};

int main() {
    int n;
    cin >> n;

    vector<int> nums(n);

    for (int i = 0; i < n; i++) {
        cin >> nums[i];
    }

    Solution obj;
    vector<int> ans = obj.separateDigits(nums);

    for (int x : ans) {
        cout << x << " ";
    }

    return 0;
}
