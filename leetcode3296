#include <bits/stdc++.h>
using namespace std;

using ll = long long;

class Solution {
public:
    ll minNumberOfSeconds(int height, vector<int>& times) {
        ll lo = 1, hi = 1e16;
        ll res = hi;

        while (lo <= hi) {
            ll mid = lo + ((hi - lo) >> 1);
            ll sum = 0;

            for (int i = 0; i < times.size() && sum < height; i++) {
                sum += (ll)(sqrt((double)mid / times[i] * 2 + 0.25) - 0.5);
            }

            if (sum >= height) {
                res = mid;
                hi = mid - 1;
            } else {
                lo = mid + 1;
            }
        }

        return res;
    }
};

int main() {
    Solution obj;

    int height;
    int n;

    cout << "Enter height: ";
    cin >> height;

    cout << "Enter number of workers: ";
    cin >> n;

    vector<int> times(n);
    cout << "Enter times array: ";
    for (int i = 0; i < n; i++) {
        cin >> times[i];
    }

    long long result = obj.minNumberOfSeconds(height, times);

    cout << "Minimum seconds required: " << result << endl;

    return 0;
}
